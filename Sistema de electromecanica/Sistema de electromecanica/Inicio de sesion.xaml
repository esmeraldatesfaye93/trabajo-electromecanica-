<Window x:Class="Sistema_de_electromecanica.Inicio_de_sesion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Sistema_de_electromecanica"
        mc:Ignorable="d"
        Title=""
        Height="450"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F4F6F9">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <!-- Panel izquierdo -->
        <Border Background="#1E293B">
            <StackPanel VerticalAlignment="Center" Margin="40">

                <TextBlock Text="Sistema Empresarial"
                   FontSize="30"
                   FontWeight="Bold"
                   Foreground="White"/>

                <TextBlock Text="Control de cotizaciones y administración"
                   FontSize="14"
                   Margin="0,10,0,0"
                   Foreground="#CBD5E1"
                   TextWrapping="Wrap"/>

                <Separator Margin="0,25,0,25"
                   Background="#475569"/>

                <TextBlock Text="Acceso seguro al sistema"
                   Foreground="#E2E8F0"
                   FontSize="16"
                   FontWeight="SemiBold"
                   TextWrapping="Wrap"/>

            </StackPanel>
        </Border>

        <Grid Grid.Column="1">
            <Border Width="350"
                    Height="320"
                    Background="White"
                    CornerRadius="12"
                    Padding="35"
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center">

                <StackPanel Margin="0,0,-8,-28">

                    <TextBlock Text="Bienvenido"
                               FontSize="28"
                               FontWeight="Bold"
                               Foreground="#0F172A"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="Inicia sesión para continuar"
                               FontSize="13"
                               Foreground="Gray"
                               Margin="0,5,0,25"
                               HorizontalAlignment="Center"/>

                    <!-- Usuario -->
                    <TextBlock Text="Usuario"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <TextBox x:Name="txtUsuario"
                             Height="38"
                             FontSize="14"
                             Padding="10"
                             Margin="0,0,0,15"/>

                    <!-- Contraseña -->
                    <TextBlock Text="Contraseña"
                               FontWeight="SemiBold"
                               Margin="0,0,0,5"/>

                    <PasswordBox x:Name="txtPassword"
                                 Height="38"
                                 FontSize="14"
                                 Padding="10"
                                 Margin="0,0,0,25"/>
                    <Button Content="INICIAR SESIÓN"
                            Height="23"
                            FontWeight="Bold"
                            FontSize="14"
                            Background="#2563EB"
                            Foreground="White"
                            BorderThickness="0"
                            Cursor="Hand"
                            Click="BtnLogin_Click" RenderTransformOrigin="0.5,0.5" Width="154">
                        <Button.RenderTransform>
                            <TransformGroup>
                                <ScaleTransform ScaleY="1"/>
                                <SkewTransform/>
                                <RotateTransform Angle="0.273"/>
                                <TranslateTransform/>
                            </TransformGroup>
                        </Button.RenderTransform>
                    </Button>

                    <!-- Botón -->

                    <TextBlock x:Name="lblError"
                               Foreground="Red"
                               FontSize="12"
                               Margin="0,15,0,0"
                               TextAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
