<Window x:Class="SistemaCotizacionesWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sistema de Cotizaciones y APU" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <Grid Background="#F5F5F5">
        <TabControl>
            <!-- ═══════════════════════════════════════════════════ -->
            <!-- TAB 1: COTIZACIÓN                                   -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TabItem Header="Cotización" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- Panel de entrada -->
                    <Border Grid.Row="0" Margin="10" Background="White" Padding="15">
                        <StackPanel>
                            <TextBlock Text="Agregar Artículo" FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="5">
                                <TextBlock Text="Producto" FontWeight="Bold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="comboProducto" Height="30" Padding="8"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Text="Proveedor" FontWeight="Bold" Margin="0,0,0,5"/>
                                <ComboBox x:Name="comboProveedor" Height="30" Padding="8"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" Margin="5">
                                <TextBlock Text="Cantidad" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtCantidad" Height="30" Padding="8" Text="1"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="5">
                                <TextBlock Text="Precio Unitario" FontWeight="Bold" Margin="0,0,0,5"/>
                                <TextBox x:Name="txtPrecio" Height="30" Padding="8" IsReadOnly="True" Background="#EEEEEE"/>
                            </StackPanel>

                            <Button Grid.Column="4" x:Name="BtnAgregar" Click="BtnAgregar_Click" 
                                    Content="Agregar" Width="100" Height="30" Margin="5,18,5,0" 
                                    Background="#4CAF50" Foreground="White" FontWeight="Bold"/>

                            <Button Grid.Column="5" x:Name="BtnAbrirCatalogo" Click="BtnAbrirCatalogo_Click" 
                                    Content="Catálogo" Width="100" Height="30" Margin="5,18,5,0" 
                                    Background="#2196F3" Foreground="White" FontWeight="Bold"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    <!-- DataGrid -->
                    <DataGrid Grid.Row="1" x:Name="grid" Margin="10" AutoGenerateColumns="True" 
                              CanUserAddRows="False" CanUserDeleteRows="False" IsReadOnly="True"
                              Background="White" GridLinesVisibility="All" HorizontalGridLinesBrush="#CCCCCC"
                              VerticalGridLinesBrush="#CCCCCC" BorderThickness="1" BorderBrush="#999999"/>

                    <!-- Panel de botones y total -->
                    <Border Grid.Row="2" Margin="10" Background="White" Padding="15">
                        <StackPanel Orientation="Horizontal">
                        <Button x:Name="BtnEliminar" Click="BtnEliminar_Click" 
                                Content="Eliminar Seleccionados" Width="150" Height="35" 
                                Background="#F44336" Foreground="White" FontWeight="Bold" Margin="0,0,10,0"/>

                        <Button x:Name="BtnPDF" Click="BtnPDF_Click" 
                                Content="Exportar PDF" Width="150" Height="35" 
                                Background="#FF9800" Foreground="White" FontWeight="Bold" Margin="0,0,20,0"/>

                        <TextBlock x:Name="lblTotal" FontSize="14" FontWeight="Bold" 
                                   Text="Total: $0.00" VerticalAlignment="Center" Margin="20,0,0,0"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </TabItem>
            
            

            <TabItem Header="APU - Análisis de Precios Unitarios">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10">

                        <TextBlock Text="Análisis de Precios Unitarios"
                       FontSize="20" FontWeight="Bold"
                       Margin="0,0,0,10"
                       HorizontalAlignment="Center"/>

                        <!-- ENCABEZADO OBRA -->
                        <Border BorderBrush="#AAAAAA" BorderThickness="1"
                    Margin="0,0,0,10">
                            <Grid Background="#F0F0F0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Obra:" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="5,0"/>
                                <TextBox x:Name="txtApuObra"
                             Grid.Row="0" Grid.Column="1"
                             Height="24" Margin="3"
                             VerticalAlignment="Center" Padding="3"/>
                                <TextBlock Grid.Row="0" Grid.Column="2"
                               Text="Lugar:" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="5,0"/>
                                <TextBox x:Name="txtApuLugar"
                             Grid.Row="0" Grid.Column="3"
                             Height="24" Margin="3"
                             VerticalAlignment="Center" Padding="3"/>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="Análisis:" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="5,0"/>
                                <TextBox x:Name="txtApuNumero"
                             Grid.Row="1" Grid.Column="1"
                             Height="24" Margin="3" Width="60"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Center" Padding="3"/>
                            </Grid>
                        </Border>

                        <!-- FILA DESCRIPCIÓN DEL CONCEPTO -->
                        <Border BorderBrush="#1a3a6b" BorderThickness="1"
                    Background="#1a3a6b" Margin="0,0,0,2">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="120"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                               Text="Análisis:"
                               Foreground="White" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="5,4"/>
                                <TextBox x:Name="txtApuDescripcion"
                             Grid.Column="1"
                             Height="26" Margin="3,3"
                             Padding="3" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtApuUnidad"
                             Grid.Column="2"
                             Height="26" Margin="3,3"
                             Padding="3" VerticalAlignment="Center"/>
                                <TextBox x:Name="txtApuCantidad"
                             Grid.Column="3" Text="1"
                             Height="26" Margin="3,3"
                             Padding="3" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblApuPrecioUnitario"
                               Grid.Column="4"
                               Text="$0.00"
                               Foreground="White" FontWeight="Bold"
                               FontSize="14"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- ═══════════ SECCIÓN MATERIALES ═══════════ -->
                        <Border Background="#5a7fa8" Margin="0,5,0,0">
                            <TextBlock Text="MATERIALES"
                           Foreground="White" FontWeight="Bold"
                           Padding="8,4"/>
                        </Border>

                        <!-- Catálogo para seleccionar materiales -->
                        <Border BorderBrush="#CCCCCC" BorderThickness="1"
                    Margin="0,0,0,2">
                            <StackPanel>
                                <TextBlock Text="Catálogo de Materiales"
                               FontSize="11" Foreground="Gray"
                               Margin="5,3"/>
                                <DataGrid x:Name="gridCatalogoMateriales"
                              Height="120"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              CanUserAddRows="False"
                              IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column"
                              FontSize="12">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="N° Serie"
                                                Binding="{Binding NumeroSerie}"
                                                Width="90"/>
                                        <DataGridTextColumn Header="Material"
                                                Binding="{Binding Material}"
                                                Width="*"/>
                                        <DataGridTextColumn Header="Unidad"
                                                Binding="{Binding Unidad}"
                                                Width="70"/>
                                        <DataGridTextColumn Header="P. Unitario"
                                                Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                                Width="90"/>
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal" Margin="5,4">
                                    <TextBlock Text="Cantidad:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                    <TextBox x:Name="txtCantidadMaterial"
                                 Width="60" Height="26" Text="1" Padding="3"/>
                                    <Button Content="+ Agregar Material"
                                Height="26" Margin="8,0,5,0" Padding="8,0"
                                Background="#1a3a6b" Foreground="White"
                                Click="BtnAgregarMaterialAPU_Click"/>
                                    <Button Content="- Quitar"
                                Height="26" Padding="8,0"
                                Background="#8B0000" Foreground="White"
                                Click="BtnQuitarMaterialAPU_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Tabla materiales seleccionados -->
                        <DataGrid x:Name="gridMaterialesSeleccionados"
                      Height="100"
                      AutoGenerateColumns="False"
                      SelectionMode="Single"
                      CanUserAddRows="False"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      FontSize="12"
                      Margin="0,0,0,0">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="N° Serie"
                                        Binding="{Binding NumeroSerie}"
                                        Width="90"/>
                                <DataGridTextColumn Header="Material"
                                        Binding="{Binding Material}"
                                        Width="*"/>
                                <DataGridTextColumn Header="Unidad"
                                        Binding="{Binding Unidad}"
                                        Width="70"/>
                                <DataGridTextColumn Header="P. Unitario"
                                        Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                        Width="90"/>
                                <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Cantidad}"
                                        Width="70"/>
                                <DataGridTextColumn Header="Subtotal"
                                        Binding="{Binding Subtotal, StringFormat=\{0:0.00\}}"
                                        Width="90"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Subtotal Materiales -->
                        <Border Background="#1a3a6b" Margin="0,0,0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                               Text="SUBTOTAL:  MATERIALES"
                               Foreground="White" FontWeight="Bold"
                               Padding="8,4"/>
                                <TextBlock x:Name="lblSubtotalMateriales"
                               Grid.Column="1"
                               Text="$0.00"
                               Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Padding="5,4"/>
                                <TextBlock x:Name="lblPctMateriales"
                               Grid.Column="2"
                               Text="0.00%"
                               Foreground="White"
                               HorizontalAlignment="Right"
                               Padding="5,4"/>
                            </Grid>
                        </Border>

                        <!-- ═══════════ SECCIÓN MANO DE OBRA ═══════════ -->
                        <Border Background="#5a7fa8" Margin="0,5,0,0">
                            <TextBlock Text="MANO DE OBRA"
                           Foreground="White" FontWeight="Bold"
                           Padding="8,4"/>
                        </Border>

                        <DataGrid x:Name="gridManoObra"
                      Height="120"
                      AutoGenerateColumns="False"
                      SelectionMode="Single"
                      CanUserAddRows="True"
                      IsReadOnly="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      FontSize="12"
                      Margin="0,0,0,0"
                      CellEditEnding="Grid_CellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Clave"
                                        Binding="{Binding NumeroSerie}"
                                        Width="90"/>
                                <DataGridTextColumn Header="Descripción"
                                        Binding="{Binding Material}"
                                        Width="*"/>
                                <DataGridTextColumn Header="Unidad"
                                        Binding="{Binding Unidad}"
                                        Width="70"/>
                                <DataGridTextColumn Header="Salario"
                                        Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                        Width="90"/>
                                <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Cantidad}"
                                        Width="70"/>
                                <DataGridTextColumn Header="Importe"
                                        Binding="{Binding Subtotal, StringFormat=\{0:0.00\}}"
                                        Width="90"
                                        IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Subtotal Mano de Obra -->
                        <Border Background="#1a3a6b" Margin="0,0,0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                               Text="SUBTOTAL:  MANO DE OBRA"
                               Foreground="White" FontWeight="Bold"
                               Padding="8,4"/>
                                <TextBlock x:Name="lblSubtotalManoObra"
                               Grid.Column="1"
                               Text="$0.00"
                               Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Padding="5,4"/>
                                <TextBlock x:Name="lblPctManoObra"
                               Grid.Column="2"
                               Text="0.00%"
                               Foreground="White"
                               HorizontalAlignment="Right"
                               Padding="5,4"/>
                            </Grid>
                        </Border>

                        <!-- ═══════════ SECCIÓN EQUIPO Y HERRAMIENTA ═══════════ -->
                        <Border Background="#5a7fa8" Margin="0,5,0,0">
                            <TextBlock Text="EQUIPO Y HERRAMIENTA"
                           Foreground="White" FontWeight="Bold"
                           Padding="8,4"/>
                        </Border>

                        <DataGrid x:Name="gridEquipo"
                      Height="120"
                      AutoGenerateColumns="False"
                      SelectionMode="Single"
                      CanUserAddRows="True"
                      IsReadOnly="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column"
                      FontSize="12"
                      Margin="0,0,0,0"
                      CellEditEnding="Grid_CellEditEnding">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Clave"
                                        Binding="{Binding NumeroSerie}"
                                        Width="90"/>
                                <DataGridTextColumn Header="Descripción"
                                        Binding="{Binding Material}"
                                        Width="*"/>
                                <DataGridTextColumn Header="Unidad"
                                        Binding="{Binding Unidad}"
                                        Width="70"/>
                                <DataGridTextColumn Header="Costo/Hr"
                                        Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                        Width="90"/>
                                <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Cantidad}"
                                        Width="70"/>
                                <DataGridTextColumn Header="Importe"
                                        Binding="{Binding Subtotal, StringFormat=\{0:0.00\}}"
                                        Width="90"
                                        IsReadOnly="True"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- Subtotal Equipo -->
                        <Border Background="#1a3a6b" Margin="0,0,0,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                               Text="SUBTOTAL:  EQUIPO Y HERRAMIENTA"
                               Foreground="White" FontWeight="Bold"
                               Padding="8,4"/>
                                <TextBlock x:Name="lblSubtotalEquipo"
                               Grid.Column="1"
                               Text="$0.00"
                               Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Right"
                               Padding="5,4"/>
                                <TextBlock x:Name="lblPctEquipo"
                               Grid.Column="2"
                               Text="0.00%"
                               Foreground="White"
                               HorizontalAlignment="Right"
                               Padding="5,4"/>
                            </Grid>
                        </Border>

                        <!-- ═══════════ RESUMEN FINAL ═══════════ -->
                        <Border BorderBrush="#AAAAAA" BorderThickness="1"
                    Margin="0,10,0,10" Padding="0">
                            <StackPanel>

                                <!-- Costo Directo -->
                                <Grid Background="#1a3a6b">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="(CD) Costo directo"
                                   Foreground="White" FontWeight="Bold"
                                   Padding="8,5"/>
                                    <TextBlock x:Name="lblCostoDirecto"
                                   Grid.Column="1"
                                   Text="$0.00"
                                   Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Padding="5,5"/>
                                    <TextBlock Grid.Column="2"
                                   Text="100.00%"
                                   Foreground="White"
                                   HorizontalAlignment="Right"
                                   Padding="5,5"/>
                                </Grid>

                                <!-- Indirectos -->
                                <Grid Background="#f5f5f5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="(CI) INDIRECTOS"
                                   Padding="8,5" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                        <TextBox x:Name="txtApuIndirectos"
                                     Width="55" Height="24" Text="12.5"
                                     Padding="3" TextChanged="TxtFactor_TextChanged"/>
                                        <TextBlock Text="%" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblIndirectos"
                                   Grid.Column="2"
                                   Text="$0.00"
                                   HorizontalAlignment="Right"
                                   Padding="5,5"/>
                                    <TextBlock Grid.Column="3" Text="" Padding="5,5"/>
                                </Grid>

                                <!-- Subtotal 1 -->
                                <Grid Background="#ddeeff">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="SUBTOTAL 1"
                                   FontWeight="Bold" Padding="8,5"/>
                                    <TextBlock Grid.Column="2"
                                   x:Name="lblSubtotal1"
                                   Text="$0.00"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Padding="5,5"/>
                                </Grid>

                                <!-- Financiamiento -->
                                <Grid Background="#f5f5f5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="(CF) FINANCIAMIENTO"
                                   Padding="8,5" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                        <TextBox x:Name="txtApuFinanciamiento"
                                     Width="55" Height="24" Text="0"
                                     Padding="3" TextChanged="TxtFactor_TextChanged"/>
                                        <TextBlock Text="%" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblFinanciamiento"
                                   Grid.Column="2"
                                   Text="$0.00"
                                   HorizontalAlignment="Right"
                                   Padding="5,5"/>
                                </Grid>

                                <!-- Subtotal 2 -->
                                <Grid Background="#ddeeff">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="SUBTOTAL 2"
                                   FontWeight="Bold" Padding="8,5"/>
                                    <TextBlock Grid.Column="2"
                                   x:Name="lblSubtotal2"
                                   Text="$0.00"
                                   FontWeight="Bold"
                                   HorizontalAlignment="Right"
                                   Padding="5,5"/>
                                </Grid>

                                <!-- Utilidad -->
                                <Grid Background="#f5f5f5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="(CU) UTILIDAD"
                                   Padding="8,5" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                        <TextBox x:Name="txtApuUtilidad"
                                     Width="55" Height="24" Text="12.5"
                                     Padding="3" TextChanged="TxtFactor_TextChanged"/>
                                        <TextBlock Text="%" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblUtilidad"
                                   Grid.Column="2"
                                   Text="$0.00"
                                   HorizontalAlignment="Right"
                                   Padding="5,5"/>
                                </Grid>

                                <!-- Precio Unitario -->
                                <Grid Background="#1a3a6b">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="PRECIO UNITARIO  (CD+CI+CF+CU)"
                                   Foreground="White" FontWeight="Bold"
                                   FontSize="13" Padding="8,6"/>
                                    <TextBlock x:Name="lblResTotal"
                                   Grid.Column="2"
                                   Text="$0.00"
                                   Foreground="White" FontWeight="Bold"
                                   FontSize="14"
                                   HorizontalAlignment="Right"
                                   Padding="5,6"/>
                                </Grid>

                                <!-- IVA -->
                                <Grid Background="#f5f5f5">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="IVA"
                                   Padding="8,5" VerticalAlignment="Center"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                    VerticalAlignment="Center">
                                        <TextBox x:Name="txtApuIva"
                                     Width="55" Height="24" Text="16"
                                     Padding="3" TextChanged="TxtFactor_TextChanged"/>
                                        <TextBlock Text="%" VerticalAlignment="Center" Margin="3,0,0,0"/>
                                    </StackPanel>
                                    <TextBlock x:Name="lblResIva"
                                   Grid.Column="2"
                                   Text="$0.00"
                                   HorizontalAlignment="Right"
                                   Padding="5,5"/>
                                </Grid>

                                <!-- Total con IVA -->
                                <Grid Background="#003366">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="80"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0"
                                   Text="TOTAL CON IVA"
                                   Foreground="White" FontWeight="Bold"
                                   FontSize="14" Padding="8,6"/>
                                    <TextBlock x:Name="lblTotalConIva"
                                   Grid.Column="2"
                                   Text="$0.00"
                                   Foreground="Yellow" FontWeight="Bold"
                                   FontSize="15"
                                   HorizontalAlignment="Right"
                                   Padding="5,6"/>
                                </Grid>

                            </StackPanel>
                        </Border>

                        <!-- BOTONES -->
                        <WrapPanel Margin="0,5,0,15">
                            <Button Content="Calcular"
                        Width="120" Height="35" Margin="5"
                        Click="BtnCalcularAPU_Click"/>
                            <Button Content="Exportar PDF"
                        Width="130" Height="35" Margin="5"
                        Click="BtnApuPDF_Click"/>
                        </WrapPanel>

                        
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
