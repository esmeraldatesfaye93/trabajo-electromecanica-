<UserControl x:Class="SistemaCotizacionesWPF.ControlAPU"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Margin="0,0,0,15">
    <Border BorderBrush="#AAAAAA" BorderThickness="1" Background="White">
        <StackPanel>

            <!-- ENCABEZADO DEL APU -->
            <Border Background="#1a3a6b" Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="80"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="130"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" x:Name="lblNumeroAPU"
                               Text="Actividad 1" Foreground="White"
                               FontWeight="Bold" FontSize="13"
                               VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <TextBox x:Name="txtUnidadAPU" Grid.Column="2"
                             Width="70" Height="26" Padding="3"
                             VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="txtCantidadAPU" Grid.Column="3"
                             Height="26" Padding="3" Text="1"
                             VerticalAlignment="Center" Margin="5,0"/>
                    <TextBlock Grid.Column="4" Text="PU:"
                               Foreground="White" VerticalAlignment="Center"
                               Margin="10,0,5,0"/>
                    <TextBlock x:Name="lblPrecioUnitarioAPU" Grid.Column="5"
                               Text="$0.00" Foreground="Yellow"
                               FontWeight="Bold" FontSize="14"
                               VerticalAlignment="Center"/>
                    <Button Grid.Column="6" Content="✕ Eliminar APU"
                            Height="26" Padding="8,0" Margin="10,0,0,0"
                            Background="#8B0000" Foreground="White"
                            Click="BtnEliminarAPU_Click"/>
                </Grid>
            </Border>

            <!-- DESCRIPCIÓN DE LA ACTIVIDAD -->
            <Border Background="#E8EDF5" Padding="8,5">
                <StackPanel>
                    <TextBlock Text="Descripción de la actividad:"
                               FontWeight="Bold" Margin="0,0,0,4" FontSize="11"/>
                    <TextBox x:Name="txtDescripcionActividad"
                             Height="55" TextWrapping="Wrap"
                             AcceptsReturn="True"
                             VerticalScrollBarVisibility="Auto"
                             Padding="6" FontSize="12"
                             BorderBrush="#AAAAAA" BorderThickness="1"/>
                </StackPanel>
            </Border>

            <!-- ═══ MATERIALES ═══ -->
            <Border Background="#5a7fa8" Margin="0,5,0,0">
                <TextBlock Text="MATERIALES" Foreground="White"
                           FontWeight="Bold" Padding="8,4"/>
            </Border>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,2">
                <StackPanel>
                    <TextBlock Text="Catálogo de Materiales"
                               FontSize="11" Foreground="Gray" Margin="5,3"/>
                    <DataGrid x:Name="gridCatalogoMat" Height="110"
                              AutoGenerateColumns="False" SelectionMode="Single"
                              CanUserAddRows="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="N° Serie"
                                                Binding="{Binding NumeroSerie}" Width="90"/>
                            <DataGridTextColumn Header="Material"
                                                Binding="{Binding Material}" Width="*"/>
                            <DataGridTextColumn Header="Unidad"
                                                Binding="{Binding Unidad}" Width="70"/>
                            <DataGridTextColumn Header="P. Unitario"
                                                Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                                Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Margin="5,4">
                        <TextBlock Text="Cantidad:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtCantidadMat" Width="60" Height="26" Text="1" Padding="3"/>
                        <Button Content="+ Agregar" Height="26" Margin="8,0,5,0" Padding="8,0"
                                Background="#1a3a6b" Foreground="White"
                                Click="BtnAgregarMat_Click"/>
                        <Button Content="- Quitar" Height="26" Padding="8,0"
                                Background="#8B0000" Foreground="White"
                                Click="BtnQuitarMat_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <DataGrid x:Name="gridMatSeleccionados" Height="90"
                      AutoGenerateColumns="False" SelectionMode="Single"
                      CanUserAddRows="True" IsReadOnly="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" FontSize="12"
                      CellEditEnding="Grid_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="N° Serie"
                                        Binding="{Binding NumeroSerie}" Width="90"/>
                    <DataGridTextColumn Header="Material"
                                        Binding="{Binding Material}" Width="*"/>
                    <DataGridTextColumn Header="Unidad"
                                        Binding="{Binding Unidad}" Width="70"/>
                    <DataGridTextColumn Header="P. Unitario"
                                        Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Cantidad}" Width="70"/>
                    <DataGridTextColumn Header="Subtotal"
                                        Binding="{Binding Subtotal, StringFormat=\{0:0.00\}}"
                                        Width="90" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Background="#1a3a6b" Margin="0,0,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SUBTOTAL:  MATERIALES"
                               Foreground="White" FontWeight="Bold" Padding="8,4"/>
                    <TextBlock x:Name="lblSubMat" Grid.Column="1" Text="$0.00"
                               Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Right" Padding="5,4"/>
                    <TextBlock x:Name="lblPctMat" Grid.Column="2" Text="0.00%"
                               Foreground="White" HorizontalAlignment="Right" Padding="5,4"/>
                </Grid>
            </Border>

            <!-- ═══ MANO DE OBRA ═══ -->
            <Border Background="#5a7fa8" Margin="0,5,0,0">
                <TextBlock Text="MANO DE OBRA" Foreground="White"
                           FontWeight="Bold" Padding="8,4"/>
            </Border>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,2">
                <StackPanel>
                    <TextBlock Text="Catálogo de Mano de Obra"
                               FontSize="11" Foreground="Gray" Margin="5,3"/>
                    <DataGrid x:Name="gridCatalogoMO" Height="90"
                              AutoGenerateColumns="False" SelectionMode="Single"
                              CanUserAddRows="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Clave"
                                                Binding="{Binding NumeroSerie}" Width="90"/>
                            <DataGridTextColumn Header="Descripción"
                                                Binding="{Binding Material}" Width="*"/>
                            <DataGridTextColumn Header="Unidad"
                                                Binding="{Binding Unidad}" Width="70"/>
                            <DataGridTextColumn Header="Salario"
                                                Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                                Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Margin="5,4">
                        <TextBlock Text="Cantidad:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtCantidadMO" Width="60" Height="26" Text="1" Padding="3"/>
                        <Button Content="+ Agregar" Height="26" Margin="8,0,5,0" Padding="8,0"
                                Background="#1a3a6b" Foreground="White"
                                Click="BtnAgregarMO_Click"/>
                        <Button Content="- Quitar" Height="26" Padding="8,0"
                                Background="#8B0000" Foreground="White"
                                Click="BtnQuitarMO_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <DataGrid x:Name="gridMO" Height="100"
                      AutoGenerateColumns="False" SelectionMode="Single"
                      CanUserAddRows="True" IsReadOnly="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" FontSize="12"
                      CellEditEnding="Grid_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Clave"
                                        Binding="{Binding NumeroSerie}" Width="90"/>
                    <DataGridTextColumn Header="Descripción"
                                        Binding="{Binding Material}" Width="*"/>
                    <DataGridTextColumn Header="Unidad"
                                        Binding="{Binding Unidad}" Width="70"/>
                    <DataGridTextColumn Header="Salario"
                                        Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Cantidad}" Width="70"/>
                    <DataGridTextColumn Header="Importe"
                                        Binding="{Binding Subtotal, StringFormat=\{0:0.00\}}"
                                        Width="90" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Background="#1a3a6b" Margin="0,0,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SUBTOTAL:  MANO DE OBRA"
                               Foreground="White" FontWeight="Bold" Padding="8,4"/>
                    <TextBlock x:Name="lblSubMO" Grid.Column="1" Text="$0.00"
                               Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Right" Padding="5,4"/>
                    <TextBlock x:Name="lblPctMO" Grid.Column="2" Text="0.00%"
                               Foreground="White" HorizontalAlignment="Right" Padding="5,4"/>
                </Grid>
            </Border>

            <!-- ═══ EQUIPO Y HERRAMIENTA ═══ -->
            <Border Background="#5a7fa8" Margin="0,5,0,0">
                <TextBlock Text="EQUIPO Y HERRAMIENTA" Foreground="White"
                           FontWeight="Bold" Padding="8,4"/>
            </Border>

            <Border BorderBrush="#CCCCCC" BorderThickness="1" Margin="0,0,0,2">
                <StackPanel>
                    <TextBlock Text="Catálogo de Equipo y Herramienta"
                               FontSize="11" Foreground="Gray" Margin="5,3"/>
                    <DataGrid x:Name="gridCatalogoEq" Height="90"
                              AutoGenerateColumns="False" SelectionMode="Single"
                              CanUserAddRows="False" IsReadOnly="True"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column" FontSize="12">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Clave"
                                                Binding="{Binding NumeroSerie}" Width="90"/>
                            <DataGridTextColumn Header="Descripción"
                                                Binding="{Binding Material}" Width="*"/>
                            <DataGridTextColumn Header="Unidad"
                                                Binding="{Binding Unidad}" Width="70"/>
                            <DataGridTextColumn Header="Costo/Hr"
                                                Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                                Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                    <StackPanel Orientation="Horizontal" Margin="5,4">
                        <TextBlock Text="Cantidad:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBox x:Name="txtCantidadEq" Width="60" Height="26" Text="1" Padding="3"/>
                        <Button Content="+ Agregar" Height="26" Margin="8,0,5,0" Padding="8,0"
                                Background="#1a3a6b" Foreground="White"
                                Click="BtnAgregarEq_Click"/>
                        <Button Content="- Quitar" Height="26" Padding="8,0"
                                Background="#8B0000" Foreground="White"
                                Click="BtnQuitarEq_Click"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <DataGrid x:Name="gridEq" Height="100"
                      AutoGenerateColumns="False" SelectionMode="Single"
                      CanUserAddRows="True" IsReadOnly="False"
                      GridLinesVisibility="Horizontal"
                      HeadersVisibility="Column" FontSize="12"
                      CellEditEnding="Grid_CellEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Clave"
                                        Binding="{Binding NumeroSerie}" Width="90"/>
                    <DataGridTextColumn Header="Descripción"
                                        Binding="{Binding Material}" Width="*"/>
                    <DataGridTextColumn Header="Unidad"
                                        Binding="{Binding Unidad}" Width="70"/>
                    <DataGridTextColumn Header="Costo/Hr"
                                        Binding="{Binding PrecioUnitario, StringFormat=\{0:0.00\}}"
                                        Width="90"/>
                    <DataGridTextColumn Header="Cantidad"
                                        Binding="{Binding Cantidad}" Width="70"/>
                    <DataGridTextColumn Header="Importe"
                                        Binding="{Binding Subtotal, StringFormat=\{0:0.00\}}"
                                        Width="90" IsReadOnly="True"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Background="#1a3a6b" Margin="0,0,0,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="SUBTOTAL:  EQUIPO Y HERRAMIENTA"
                               Foreground="White" FontWeight="Bold" Padding="8,4"/>
                    <TextBlock x:Name="lblSubEq" Grid.Column="1" Text="$0.00"
                               Foreground="White" FontWeight="Bold"
                               HorizontalAlignment="Right" Padding="5,4"/>
                    <TextBlock x:Name="lblPctEq" Grid.Column="2" Text="0.00%"
                               Foreground="White" HorizontalAlignment="Right" Padding="5,4"/>
                </Grid>
            </Border>

            <!-- ═══ RESUMEN ═══ -->
            <Border BorderBrush="#AAAAAA" BorderThickness="1" Margin="5,5,5,10">
                <StackPanel>
                    <Grid Background="#1a3a6b">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="(CD) Costo Directo"
                                   Foreground="White" FontWeight="Bold" Padding="8,5"/>
                        <TextBlock x:Name="lblCD" Grid.Column="1" Text="$0.00"
                                   Foreground="White" FontWeight="Bold"
                                   HorizontalAlignment="Right" Padding="5,5"/>
                        <TextBlock Grid.Column="2" Text="100%"
                                   Foreground="White" HorizontalAlignment="Right" Padding="5,5"/>
                    </Grid>

                    <Grid Background="#f5f5f5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="(CI) INDIRECTOS"
                                   Padding="8,5" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox x:Name="txtIndirectos" Width="50" Height="24"
                                     Text="12.5" Padding="3"
                                     TextChanged="TxtFactor_TextChanged"/>
                            <TextBlock Text="%" VerticalAlignment="Center" Margin="2,0,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="lblCI" Grid.Column="2" Text="$0.00"
                                   HorizontalAlignment="Right" Padding="5,5"/>
                    </Grid>

                    <Grid Background="#ddeeff">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SUBTOTAL 1"
                                   FontWeight="Bold" Padding="8,5"/>
                        <TextBlock x:Name="lblSub1" Grid.Column="2" Text="$0.00"
                                   FontWeight="Bold" HorizontalAlignment="Right" Padding="5,5"/>
                    </Grid>

                    <Grid Background="#f5f5f5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="(CF) FINANCIAMIENTO"
                                   Padding="8,5" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox x:Name="txtFinanciamiento" Width="50" Height="24"
                                     Text="0" Padding="3"
                                     TextChanged="TxtFactor_TextChanged"/>
                            <TextBlock Text="%" VerticalAlignment="Center" Margin="2,0,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="lblCF" Grid.Column="2" Text="$0.00"
                                   HorizontalAlignment="Right" Padding="5,5"/>
                    </Grid>

                    <Grid Background="#ddeeff">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SUBTOTAL 2"
                                   FontWeight="Bold" Padding="8,5"/>
                        <TextBlock x:Name="lblSub2" Grid.Column="2" Text="$0.00"
                                   FontWeight="Bold" HorizontalAlignment="Right" Padding="5,5"/>
                    </Grid>

                    <Grid Background="#f5f5f5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="(CU) UTILIDAD"
                                   Padding="8,5" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBox x:Name="txtUtilidad" Width="50" Height="24"
                                     Text="12.5" Padding="3"
                                     TextChanged="TxtFactor_TextChanged"/>
                            <TextBlock Text="%" VerticalAlignment="Center" Margin="2,0,0,0"/>
                        </StackPanel>
                        <TextBlock x:Name="lblCU" Grid.Column="2" Text="$0.00"
                                   HorizontalAlignment="Right" Padding="5,5"/>
                    </Grid>

                    <Grid Background="#1a3a6b">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="70"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="PRECIO UNITARIO  (CD+CI+CF+CU)"
                                   Foreground="White" FontWeight="Bold"
                                   FontSize="12" Padding="8,6"/>
                        <TextBlock x:Name="lblPU" Grid.Column="2" Text="$0.00"
                                   Foreground="White" FontWeight="Bold" FontSize="13"
                                   HorizontalAlignment="Right" Padding="5,6"/>
                    </Grid>

                </StackPanel>
            </Border>

        </StackPanel>
    </Border>
</UserControl>