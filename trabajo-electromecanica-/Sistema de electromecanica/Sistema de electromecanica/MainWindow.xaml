<Window x:Class="SistemaCotizacionesWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SistemaCotizacionesWPF"
        Title="Sistema de Cotizaciones y APU" Height="900" Width="1400"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize">
    <Grid Background="#F5F5F5">
        <TabControl>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- TAB 1: COTIZACIÓN                                   -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TabItem Header="Cotización" Padding="10">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">

                        <TextBlock Text="Sistema de Cotizaciones"
                                   FontSize="22" FontWeight="Bold"
                                   HorizontalAlignment="Center" Margin="0,0,0,10"/>

                        <!-- DATOS DEL CLIENTE -->
                        <Border Background="White" Padding="15" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="Datos del Cliente"
                                           FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="5">
                                        <TextBlock Text="Nombre:" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtClienteNombre" Height="28" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5">
                                        <TextBlock Text="Empresa:" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtClienteEmpresa" Height="28" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="5">
                                        <TextBlock Text="Teléfono:" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtClienteTelefono" Height="28" Padding="5"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Margin="5">
                                        <TextBlock Text="Correo:" FontWeight="Bold" Margin="0,0,0,4"/>
                                        <TextBox x:Name="txtClienteCorreo" Height="28" Padding="5"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- AGREGAR ARTÍCULO -->
                        <Border Background="White" Padding="15" Margin="0,0,0,5">
                            <StackPanel>
                                <TextBlock Text="Agregar Artículo"
                                           FontSize="14" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Margin="5">
                                        <TextBlock Text="Producto" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="comboProducto" Height="30" Padding="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Margin="5">
                                        <TextBlock Text="Proveedor" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <ComboBox x:Name="comboProveedor" Height="30" Padding="8"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2" Margin="5">
                                        <TextBlock Text="Cantidad" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtCantidad" Height="30" Padding="8" Text="1"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="3" Margin="5">
                                        <TextBlock Text="Precio Unitario" FontWeight="Bold" Margin="0,0,0,5"/>
                                        <TextBox x:Name="txtPrecio" Height="30" Padding="8"
                                                 IsReadOnly="True" Background="#EEEEEE"/>
                                    </StackPanel>
                                    <Button Grid.Column="4" Click="BtnAgregar_Click"
                                            Content="Agregar" Width="100" Height="30"
                                            Margin="5,18,5,0"
                                            Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                                    <Button Grid.Column="5" Click="BtnAbrirCatalogo_Click"
                                            Content="Catálogo" Width="100" Height="30"
                                            Margin="5,18,5,0"
                                            Background="#2196F3" Foreground="White" FontWeight="Bold"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- TABLA -->
                        <DataGrid x:Name="grid" Height="250" Margin="0,0,0,5"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False" CanUserDeleteRows="False"
                                  IsReadOnly="True" Background="White"
                                  GridLinesVisibility="All"
                                  HorizontalGridLinesBrush="#CCCCCC"
                                  VerticalGridLinesBrush="#CCCCCC"
                                  BorderThickness="1" BorderBrush="#999999">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Producto"
                                                    Binding="{Binding Producto}" Width="2*"/>
                                <DataGridTextColumn Header="Proveedor"
                                                    Binding="{Binding Proveedor}" Width="2*"/>
                                <DataGridTextColumn Header="Cantidad"
                                                    Binding="{Binding Cantidad}" Width="*"/>
                                <DataGridTextColumn Header="Unidad"
                                                    Binding="{Binding Unidad}" Width="*"/>
                                <DataGridTextColumn Header="Precio"
                                                    Binding="{Binding Precio, StringFormat=\{0:C\}}" Width="*"/>
                                <DataGridTextColumn Header="Subtotal"
                                                    Binding="{Binding Subtotal, StringFormat=\{0:C\}}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <!-- BOTONES Y TOTAL -->
                        <Border Background="White" Padding="15">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Click="BtnEliminar_Click"
                                        Content="Eliminar Seleccionados"
                                        Width="160" Height="35"
                                        Background="#F44336" Foreground="White"
                                        FontWeight="Bold" Margin="0,0,10,0"/>
                                <Button Grid.Column="1" Click="BtnPDF_Click"
                                        Content="Exportar PDF Cotización"
                                        Width="180" Height="35"
                                        Background="#FF9800" Foreground="White"
                                        FontWeight="Bold" Margin="0,0,20,0"/>
                                <TextBlock x:Name="lblTotal" Grid.Column="3"
                                           FontSize="16" FontWeight="Bold"
                                           Text="Total: $0.00" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══════════════════════════════════════════════════ -->
            <!-- TAB 2: APU                                          -->
            <!-- ═══════════════════════════════════════════════════ -->
            <TabItem Header="APU - Análisis de Precios Unitarios">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="10">

                        <TextBlock Text="Análisis de Precios Unitarios"
                                   FontSize="20" FontWeight="Bold"
                                   Margin="0,0,0,10" HorizontalAlignment="Center"/>

                        <!-- ENCABEZADO GENERAL -->
                        <Border BorderBrush="#AAAAAA" BorderThickness="1" Margin="0,0,0,10"
                                Background="#F0F0F0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Column="0" Text="Obra:"
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="8,0"/>
                                <TextBox x:Name="txtApuObra" Grid.Column="1"
                                         Height="24" Margin="3" VerticalAlignment="Center" Padding="3"/>
                                <TextBlock Grid.Column="2" Text="Lugar:"
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="8,0"/>
                                <TextBox x:Name="txtApuLugar" Grid.Column="3"
                                         Height="24" Margin="3" VerticalAlignment="Center" Padding="3"/>
                                <TextBlock Grid.Column="4" Text="IVA (%):"
                                           FontWeight="Bold" VerticalAlignment="Center" Margin="8,0"/>
                                <TextBox x:Name="txtIvaGlobal" Grid.Column="5"
                                         Height="24" Margin="3" Width="60"
                                         HorizontalAlignment="Left"
                                         VerticalAlignment="Center" Padding="3" Text="16"/>
                            </Grid>
                        </Border>

                        <!-- BOTÓN AGREGAR NUEVO APU -->
                        <Button Content="+ Agregar nueva Actividad APU"
                                Height="40" Margin="0,0,0,10"
                                Background="#4CAF50" Foreground="White"
                                FontSize="14" FontWeight="Bold"
                                Click="BtnNuevoAPU_Click"/>

                        <!-- CONTENEDOR DINÁMICO DE APUs -->
                        <StackPanel x:Name="panelAPUs" Margin="0,0,0,10"/>

                        <!-- ═══════ PRESUPUESTO CONSOLIDADO ═══════ -->
                        <Border Background="#1a3a6b" Margin="0,10,0,0">
                            <TextBlock Text="PRESUPUESTO CONSOLIDADO"
                                       Foreground="White" FontWeight="Bold"
                                       FontSize="14" Padding="10,6"
                                       HorizontalAlignment="Center"/>
                        </Border>

                        <Border BorderBrush="#AAAAAA" BorderThickness="1" Margin="0,0,0,5">
                            <DataGrid x:Name="gridPresupuesto" Height="220"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False" IsReadOnly="True"
                                      GridLinesVisibility="All"
                                      HorizontalGridLinesBrush="#CCCCCC"
                                      VerticalGridLinesBrush="#CCCCCC"
                                      HeadersVisibility="Column" FontSize="12">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="No."
                                                        Binding="{Binding No}" Width="40"/>
                                    <DataGridTextColumn Header="CONCEPTO"
                                                        Binding="{Binding Concepto}" Width="3*"/>
                                    <DataGridTextColumn Header="UNIDAD"
                                                        Binding="{Binding Unidad}" Width="70"/>
                                    <DataGridTextColumn Header="CANTIDAD"
                                                        Binding="{Binding Cantidad, StringFormat=\{0:0.0000\}}"
                                                        Width="90"/>
                                    <DataGridTextColumn Header="P.U."
                                                        Binding="{Binding PU, StringFormat=\{0:C\}}"
                                                        Width="110"/>
                                    <DataGridTextColumn Header="IMPORTE"
                                                        Binding="{Binding Importe, StringFormat=\{0:C\}}"
                                                        Width="120"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </Border>

                        <!-- TOTALES -->
                        <Border Background="White" BorderBrush="#AAAAAA"
                                BorderThickness="1" Padding="10" Margin="0,0,0,10">
                            <Grid HorizontalAlignment="Right" Width="320">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="140"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="30"/>
                                    <RowDefinition Height="38"/>
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Text="SUBTOTAL:"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblPresupuestoSub" Grid.Row="0" Grid.Column="1"
                                           Text="$0.00" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="1" Grid.Column="0"
                                           x:Name="lblIvaLabel" Text="IVA (16%):"
                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblPresupuestoIva" Grid.Row="1" Grid.Column="1"
                                           Text="$0.00" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Row="2" Grid.Column="0" Text="TOTAL:"
                                           FontSize="16" FontWeight="Bold"
                                           VerticalAlignment="Center"/>
                                <TextBlock x:Name="lblPresupuestoTotal" Grid.Row="2" Grid.Column="1"
                                           Text="$0.00" FontSize="16" FontWeight="Bold"
                                           Foreground="DarkGreen" HorizontalAlignment="Right"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- BOTONES FINALES -->
                        <WrapPanel Margin="0,0,0,15">
                            <Button Content="Actualizar Presupuesto"
                                    Width="200" Height="35" Margin="5"
                                    Background="#2196F3" Foreground="White" FontWeight="Bold"
                                    Click="BtnActualizarPresupuesto_Click"/>
                            <Button Content="Exportar PDF Presupuesto"
                                    Width="200" Height="35" Margin="5"
                                    Background="#FF9800" Foreground="White" FontWeight="Bold"
                                    Click="BtnPresupuestoPDF_Click"/>
                        </WrapPanel>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</Window>